datasource db {
  provider  = "postgresql"
}

generator client {
  provider = "prisma-client-js"
   output   = "../generated/prisma"
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  posts    Post[]
}

model Post {
  id          String   @id @default(uuid())
  title       String
  description String
  latitude    Float
  longitude   Float
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}